---
import { useTranslations } from '../i18n';

const t = useTranslations('es');
---

<section id="manifiesto" class="statement container">
  <h2 class="label" data-reveal>{t.statement.label}</h2>
  <p class="text" data-reveal style="--reveal-delay: 140ms">{t.statement.text}</p>
</section>

<style>
  .statement {
    padding-block: var(--space-section);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-lg);
  }

  .text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-2xl);
    font-weight: 420;
    line-height: 1.3;
    max-width: 24ch;
    text-wrap: balance;
  }
</style>
