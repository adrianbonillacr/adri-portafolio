---
import { useTranslations } from '../i18n';

const t = useTranslations('es');
---

<section id="manifiesto" class="statement container">
  <p class="text" data-reveal>{t.statement.text}</p>
</section>

<style>
  .statement {
    padding-block: var(--space-section);
    display: flex;
    justify-content: center;
    text-align: center;
  }

  .text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-2xl);
    font-weight: 420;
    line-height: 1.3;
    max-width: 24ch;
    text-wrap: balance;
  }
</style>
