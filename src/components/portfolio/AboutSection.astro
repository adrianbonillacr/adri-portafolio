---
/**
 * Sobre mí — resumen sólido del CV para quien no viene del currículum:
 * retrato, historia breve, cifras, roles desempeñados, formación y
 * marcas; cierra con los tres pilares (pienso / trabajo / resuelvo).
 *
 * El retrato se detecta solo: basta colocar la foto en
 * public/portfolio/sobre-mi/hero.jpg (o .png/.webp/.avif).
 */
import { getLangFromUrl, useTranslations } from '../../i18n';
import { getProjectMedia } from '../../lib/media';
import SectionHeader from './SectionHeader.astro';
import MediaFrame from './MediaFrame.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const portrait = getProjectMedia('sobre-mi').hero;

/**
 * Iconos monolínea de los pilares (trazo 1.5, currentColor):
 * brújula → cómo pienso · capas → cómo trabajo · diana → qué resuelvo.
 */
const pillarIcons = [
  `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true"><circle cx="14" cy="14" r="10.5"/><path d="M18.2 9.8 15.6 15.6 9.8 18.2l2.6-5.8z"/></svg>`,
  `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true"><path d="m14 4.5 9.5 5L14 14.5l-9.5-5z"/><path d="m4.5 14.5 9.5 5 9.5-5"/><path d="m4.5 19 9.5 5 9.5-5"/></svg>`,
  `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="14" cy="14" r="10.5"/><circle cx="14" cy="14" r="5.75"/><circle cx="14" cy="14" r="1.4" fill="currentColor" stroke="none"/></svg>`,
];
---

<section id="sobre-mi" class="about container">
  <SectionHeader label={t.portfolio.about.label} title={t.portfolio.about.title} />

  <div class="profile">
    <div class="portrait" data-reveal>
      <MediaFrame
        src={portrait}
        alt={t.portfolio.about.portraitAlt}
        ratio="4 / 5"
        label={lang === 'en' ? 'portrait' : 'retrato'}
      />
    </div>

    <div class="resume">
      <div class="bio" data-reveal style="--reveal-delay: 120ms">
        {t.portfolio.about.bio.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <dl class="stats" data-reveal style="--reveal-delay: 220ms">
        {
          t.portfolio.about.stats.map((stat) => (
            <div class="stat">
              <dd>{stat.value}</dd>
              <dt>{stat.label}</dt>
            </div>
          ))
        }
      </dl>

      <div class="block" data-reveal style="--reveal-delay: 300ms">
        <span class="block-label">{t.portfolio.about.rolesLabel}</span>
        <ul class="chips">
          {t.portfolio.about.roles.map((role) => <li>{role}</li>)}
        </ul>
      </div>

      <div class="block" data-reveal style="--reveal-delay: 380ms">
        <span class="block-label">{t.portfolio.about.educationLabel}</span>
        <ul class="plain">
          {t.portfolio.about.education.map((entry) => <li>{entry}</li>)}
        </ul>
      </div>

      <div class="block" data-reveal style="--reveal-delay: 460ms">
        <span class="block-label">{t.portfolio.about.clientsLabel}</span>
        <p class="clients">{t.portfolio.about.clients.join(' · ')}</p>
      </div>
    </div>
  </div>

  <div class="grid">
    {
      t.portfolio.about.items.map((item, index) => (
        <article data-reveal style={`--reveal-delay: ${index * 120}ms`}>
          <div class="pillar-head">
            <span class="pillar-icon" set:html={pillarIcons[index] ?? pillarIcons[0]} />
            <span class="index" aria-hidden="true">
              {String(index + 1).padStart(2, '0')}
            </span>
          </div>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  /* solo padding superior: el espacio entre secciones lo aporta una
     única sección, evitando dobles bloques en blanco */
  .about {
    padding-block: var(--space-section) 0;
  }

  .profile {
    display: grid;
    grid-template-columns: minmax(16rem, 2fr) 3fr;
    gap: var(--space-xl);
    align-items: start;
    margin-bottom: var(--space-xl);
  }

  .portrait {
    position: sticky;
    top: calc(var(--frame) + var(--space-lg));
  }

  .resume {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .bio p {
    color: var(--color-ink-muted);
    max-width: 58ch;
    text-wrap: pretty;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    padding-block: var(--space-sm);
    border-block: 1px solid var(--color-line-soft);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* cifras en Bodoni: acento editorial secundario de la marca */
  .stat dd {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 420;
    line-height: 1;
  }

  .stat dt {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.18em;
    color: var(--color-ink-faint);
  }

  .block {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .block-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.26em;
    color: var(--color-ink-faint);
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chips li {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.14em;
    color: var(--color-ink-muted);
    border: 1px solid var(--color-line-soft);
    padding: 0.3rem 0.7rem;
  }

  .plain li {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    padding-left: 1.1rem;
    position: relative;
  }

  .plain li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-ink-faint);
  }

  .clients {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.9;
    color: var(--color-ink-muted);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  article {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-line-soft);
  }

  .pillar-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
  }

  .pillar-icon {
    display: inline-flex;
    color: var(--color-ink-muted);
  }

  .pillar-icon :global(svg) {
    width: 28px;
    height: 28px;
  }

  .index {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.3em;
    color: var(--color-ink-faint);
  }

  h3 {
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  article p {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 900px) {
    .profile {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .portrait {
      position: static;
      max-width: 24rem;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .stats {
      gap: var(--space-sm);
    }
  }
</style>
