---
/**
 * Estructura completa y única de un caso de estudio.
 * La usan tanto las páginas de proyecto (/portafolio/<id>) como los
 * casos anidados (/portafolio/<id>/<caso>), de modo que todas
 * comparten exactamente la misma arquitectura:
 * hero → desafío/objetivo/rol/estrategia → [negocios y casos] →
 * proceso → resultados → galería → próximo proyecto.
 *
 * Los negocios/casos van inmediatamente después del bloque estratégico
 * para que el visitante encuentre el trabajo real antes de recorrer
 * proceso, resultados y galería. En las páginas de caso individual
 * (sin `caseStudies`) la estructura queda igual que antes.
 */
import { getProjectMedia } from '../../lib/media';
import ProjectHero from './ProjectHero.astro';
import ProjectBrief from './ProjectBrief.astro';
import ProcessSection from './ProcessSection.astro';
import ResultsSection from './ResultsSection.astro';
import ProjectGallery from './ProjectGallery.astro';
import CaseStudyList from './CaseStudyList.astro';
import NextProject from './NextProject.astro';

interface Props {
  /** Carpeta de medios bajo public/portfolio/, ej. 'distrito11' o 'advanced/proyecto-1'. */
  mediaId: string;
  title: string;
  tagline: string;
  description: string;
  disciplines: string[];
  challenge: string;
  objective: string;
  role: string;
  strategy: string;
  process: { title: string; description: string }[];
  /** Si no hay resultados reales todavía, se omite la sección por completo. */
  results?: { summary: string; metrics: { value: string; label: string }[] };
  galleryPlaceholders?: number;
  /** Solo proyectos contenedores: casos anidados a listar. */
  caseStudies?: { id: string; title: string; tagline: string; description: string }[];
  next: { title: string; href: string };
  backHref?: string;
  backLabel?: string;
}

const {
  mediaId,
  title,
  tagline,
  description,
  disciplines,
  challenge,
  objective,
  role,
  strategy,
  process,
  results,
  galleryPlaceholders = 6,
  caseStudies = [],
  next,
  backHref,
  backLabel,
} = Astro.props;

const media = getProjectMedia(mediaId);
---

<article>
  <ProjectHero
    {title}
    {tagline}
    {description}
    {disciplines}
    hero={media.hero}
    heroVideo={media.heroVideo}
    {backHref}
    {backLabel}
  />

  <ProjectBrief {challenge} {objective} {role} {strategy} />

  {caseStudies.length > 0 && <CaseStudyList projectId={mediaId} caseStudies={caseStudies} />}

  <ProcessSection steps={process} processVideo={media.videos.process ?? null} />

  {results && <ResultsSection summary={results.summary} metrics={results.metrics} />}

  <ProjectGallery
    items={media.gallery}
    categories={media.galleryCategories}
    placeholders={galleryPlaceholders}
    projectTitle={title}
  />

  <NextProject href={next.href} title={next.title} />
</article>
