---
/**
 * Navegación de casos de estudio anidados (Advanced, LAGE):
 * reutiliza exactamente la misma tarjeta premium del portafolio.
 */
import { getLangFromUrl, useTranslations } from '../../i18n';
import { getProjectMedia } from '../../lib/media';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projectId: string;
  caseStudies: { id: string; title: string; tagline: string; description: string }[];
}

const { projectId, caseStudies } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="case-studies container">
  <span class="label" data-reveal>{t.portfolio.project.caseStudies}</span>

  <div class="grid">
    {
      caseStudies.map((caseStudy, index) => {
        const media = getProjectMedia(`${projectId}/${caseStudy.id}`);
        return (
          <ProjectCard
            href={`${t.portfolio.base}/${projectId}/${caseStudy.id}`}
            title={caseStudy.title}
            tagline={caseStudy.tagline}
            disciplines={[]}
            index={index}
            image={media.card ?? media.hero}
            video={media.heroVideo}
          />
        );
      })
    }
  </div>
</section>

<style>
  .case-studies {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-block: var(--space-xl);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
