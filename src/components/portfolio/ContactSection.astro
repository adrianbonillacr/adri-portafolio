---
/**
 * Contacto: cierre editorial de la sección con correo y redes.
 * Coherente con el manifiesto del sitio (display itálica centrada).
 */
import { getLangFromUrl, useTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contacto" class="contact container">
  <span class="label" data-reveal>{t.portfolio.contact.label}</span>

  <h2 data-reveal style="--reveal-delay: 120ms">{t.portfolio.contact.title}</h2>

  <p class="text" data-reveal style="--reveal-delay: 220ms">{t.portfolio.contact.text}</p>

  <div class="channels" data-reveal style="--reveal-delay: 320ms">
    <div class="channel">
      <span class="channel-label">{t.portfolio.contact.emailLabel}</span>
      <a class="email" href={`mailto:${t.portfolio.contact.email}`}>{t.portfolio.contact.email}</a>
    </div>

    <div class="channel">
      <span class="channel-label">{t.portfolio.contact.phoneLabel}</span>
      <a class="email" href={`tel:${t.portfolio.contact.phone.replaceAll(' ', '')}`}>
        {t.portfolio.contact.phone}
      </a>
    </div>

    <div class="channel">
      <span class="channel-label">{t.portfolio.contact.locationLabel}</span>
      <span class="plain-value">{t.portfolio.contact.location}</span>
    </div>

    <div class="channel">
      <span class="channel-label">{t.portfolio.contact.socialLabel}</span>
      <ul>
        {
          t.portfolio.contact.socials.map((social) => (
            <li>
              <a href={social.url} target="_blank" rel="noopener noreferrer">
                {social.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    padding-block: var(--space-section);
  }

  h2 {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-2xl);
    font-weight: 420;
    line-height: 1.2;
    text-wrap: balance;
  }

  .text {
    color: var(--color-ink-muted);
    max-width: 40ch;
  }

  .channels {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-xl);
    margin-top: var(--space-md);
  }

  .channel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .channel-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.3em;
    color: var(--color-ink-faint);
  }

  .email {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .plain-value {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
  }

  .email:hover {
    opacity: 0.7;
  }

  .channel ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .channel ul a {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.22em;
    color: var(--color-ink-muted);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .channel ul a:hover {
    color: var(--color-ink);
  }
</style>
