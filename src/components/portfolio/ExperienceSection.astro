---
/**
 * Experiencia profesional en formato timeline: línea vertical con
 * marcadores y, por etapa, cabecera (empresa/cargo/fechas), resumen
 * y bloques a todo lo ancho de la pantalla (responsabilidades,
 * logros, herramientas). Si la etapa tiene espacio relacionado,
 * enlaza a su página del portafolio.
 */
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n';
import SectionHeader from './SectionHeader.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const entries = (await getCollection(lang === 'en' ? 'experienceEn' : 'experience')).sort(
  (a, b) => a.data.order - b.data.order
);
const projects = await getCollection(lang === 'en' ? 'projectsEn' : 'projects');
const projectIds = new Set(projects.map((project) => project.id));
---

<section id="experiencia" class="experience container">
  <SectionHeader label={t.portfolio.experience.label} title={t.portfolio.experience.title} />

  <ol class="timeline">
    {
      entries.map((entry, index) => {
        const { data } = entry;
        const hasProject = data.projectId && projectIds.has(data.projectId);
        return (
          <li data-reveal style={`--reveal-delay: ${(index % 3) * 100}ms`}>
            <span class="marker" aria-hidden="true" />

            <header class="head">
              <div class="who">
                <h3>{data.company}</h3>
                <p class="role">{data.role}</p>
              </div>
              <span class="period">{data.period}</span>
            </header>

            <p class="summary">{data.summary}</p>

            <div class="block">
              <span class="block-label">{t.portfolio.experience.responsibilities}</span>
              <ul>
                {data.responsibilities.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>

            <div class="block">
              <span class="block-label">{t.portfolio.experience.achievements}</span>
              <ul>
                {data.achievements.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>

            <div class="block">
              <span class="block-label">{t.portfolio.experience.tools}</span>
              <ul class="chips">
                {data.tools.map((tool) => (
                  <li>{tool}</li>
                ))}
              </ul>
            </div>

            {hasProject && (
              <a class="project-link" href={`${t.portfolio.base}/${data.projectId}`}>
                {t.portfolio.experience.viewProject} →
              </a>
            )}
          </li>
        );
      })
    }
  </ol>
</section>

<style>
  .experience {
    padding-block: var(--space-section) 0;
  }

  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding-left: clamp(1.75rem, 4vw, 3rem);
  }

  /* línea vertical continua del timeline */
  .timeline::before {
    content: '';
    position: absolute;
    top: 0.4rem;
    bottom: 0.4rem;
    left: 0;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-line) 8%,
      var(--color-line) 92%,
      transparent
    );
  }

  /* cada etapa fluye a lo ancho completo de la pantalla */
  li {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .marker {
    position: absolute;
    top: 0.5rem;
    left: calc(-1 * clamp(1.75rem, 4vw, 3rem));
    translate: -50% 0;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1px solid var(--color-ink-muted);
    background: var(--color-bg);
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-md);
  }

  .who {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  h3 {
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.015em;
  }

  .role {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .period {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.18em;
    color: var(--color-ink-faint);
  }

  .summary {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }

  .block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    margin-top: var(--space-2xs);
  }

  .block-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.18em;
    color: var(--color-ink-faint);
  }

  .block ul:not(.chips) li {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    padding-left: 1.1rem;
    position: relative;
  }

  .block ul:not(.chips) li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-ink-faint);
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chips li {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.14em;
    color: var(--color-ink-faint);
    border: 1px solid var(--color-line-soft);
    padding: 0.3rem 0.7rem;
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.18em;
    color: var(--color-ink-muted);
    margin-top: var(--space-2xs);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .project-link:hover {
    color: var(--color-ink);
  }
</style>
