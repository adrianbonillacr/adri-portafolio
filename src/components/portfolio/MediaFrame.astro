---
/**
 * Marco de imagen consciente de placeholders: si `src` existe renderiza
 * la imagen (lazy por defecto); si no, un marco vacío de galería con
 * etiqueta mono. Así las páginas quedan listas antes de tener medios.
 */
interface Props {
  src: string | null;
  alt: string;
  /** Relación de aspecto CSS, ej. '4 / 3', '16 / 9'. */
  ratio?: string;
  /** Etiqueta del placeholder cuando no hay imagen. */
  label?: string;
  loading?: 'lazy' | 'eager';
}

const { src, alt, ratio = '4 / 3', label = 'imagen', loading = 'lazy' } = Astro.props;
---

<figure class="media-frame" style={`--ratio: ${ratio}`}>
  {
    src ? (
      <img
        src={src}
        alt={alt}
        loading={loading}
        decoding="async"
        fetchpriority={loading === 'eager' ? 'high' : 'auto'}
      />
    ) : (
      <span class="placeholder" role="img" aria-label={alt}>
        <span class="tag">{label}</span>
      </span>
    )
  }
</figure>

<style>
  .media-frame {
    position: relative;
    aspect-ratio: var(--ratio);
    overflow: hidden;
    background: var(--color-bg-raised);
    border: 1px solid var(--color-line-soft);
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* cruz diagonal sutil, como un lienzo en espera */
  .placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top right,
        transparent calc(50% - 0.5px),
        var(--color-line-soft) 50%,
        transparent calc(50% + 0.5px)
      ),
      linear-gradient(
        to bottom right,
        transparent calc(50% - 0.5px),
        var(--color-line-soft) 50%,
        transparent calc(50% + 0.5px)
      );
  }

  .tag {
    position: relative;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.3em;
    text-transform: lowercase;
    color: var(--color-ink-faint);
    background: var(--color-bg-raised);
    padding: 0.5rem 1rem;
  }
</style>
