---
/**
 * Marco de imagen consciente de placeholders: si `src` existe renderiza
 * la imagen (lazy por defecto); si no, un marco vacío de galería con
 * la especificación del archivo esperado — etiqueta, proporción y
 * tamaño recomendado en píxeles — para producir los assets a mano.
 */
interface Props {
  src: string | null;
  alt: string;
  /** Relación de aspecto CSS, ej. '4 / 3', '16 / 9'. */
  ratio?: string;
  /** Etiqueta del placeholder cuando no hay imagen. */
  label?: string;
  loading?: 'lazy' | 'eager';
}

const { src, alt, ratio = '4 / 3', label = 'imagen', loading = 'lazy' } = Astro.props;

/**
 * Tamaño de exportación recomendado según la proporción:
 * panorámicos (≥2:1) 2400px de ancho, horizontales 1600px,
 * verticales 1200px; la altura se deriva del ratio.
 */
const [ratioW = 4, ratioH = 3] = ratio.split('/').map((part) => parseFloat(part.trim()));
const aspect = ratioW / ratioH;
const exportWidth = aspect >= 2 ? 2400 : aspect >= 1 ? 1600 : 1200;
const exportHeight = Math.round(exportWidth / aspect);
const ratioLabel = `${ratioW}:${ratioH}`;
const sizeLabel = `${exportWidth}px × ${exportHeight}px`;
---

<figure class="media-frame" style={`--ratio: ${ratio}`}>
  {
    src ? (
      <img
        src={src}
        alt={alt}
        loading={loading}
        decoding="async"
        fetchpriority={loading === 'eager' ? 'high' : 'auto'}
      />
    ) : (
      <span class="placeholder" role="img" aria-label={alt}>
        <span class="specs">
          <span class="tag">{label}</span>
          <span class="spec">{ratioLabel}</span>
          <span class="spec">{sizeLabel}</span>
        </span>
      </span>
    )
  }
</figure>

<style>
  .media-frame {
    position: relative;
    aspect-ratio: var(--ratio);
    overflow: hidden;
    background: var(--color-bg-raised);
    border: 1px solid var(--color-line-soft);
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* cruz diagonal sutil, como un lienzo en espera */
  .placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top right,
        transparent calc(50% - 0.5px),
        var(--color-line-soft) 50%,
        transparent calc(50% + 0.5px)
      ),
      linear-gradient(
        to bottom right,
        transparent calc(50% - 0.5px),
        var(--color-line-soft) 50%,
        transparent calc(50% + 0.5px)
      );
  }

  .specs {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    background: var(--color-bg-raised);
    padding: 0.7rem 1.1rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.3em;
    color: var(--color-ink-faint);
  }

  .spec {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }
</style>
