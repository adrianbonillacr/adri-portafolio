---
/**
 * Hero del portafolio profesional — composición editorial:
 * cejilla (etiqueta + línea + ubicación), lockup del nombre,
 * headline dominante alineado a la izquierda, propuesta de valor
 * con CTAs, y barra de meta al pie con rol y cifras clave.
 */
import { getLangFromUrl, useTranslations } from '../../i18n';
import CtaLink from './CtaLink.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const stats = t.portfolio.about.stats.map((stat) => `${stat.value} ${stat.label}`);
---

<section class="portfolio-hero">
  <div class="inner">
    <div class="eyebrow" data-reveal>
      <span class="label">{t.portfolio.hero.label}</span>
      <span class="rule" aria-hidden="true"></span>
      <span class="place">{t.portfolio.hero.location}</span>
    </div>

    <h1 class="name" data-reveal style="--reveal-delay: 120ms">
      <span class="first">{t.hero.firstName}</span>
      <span class="last">{t.hero.lastName}</span>
    </h1>

    <p class="headline" data-reveal style="--reveal-delay: 240ms">
      {t.portfolio.hero.headline}
    </p>

    <div class="row" data-reveal style="--reveal-delay: 380ms">
      <p class="value">{t.portfolio.hero.value}</p>
      <div class="actions">
        <CtaLink href="#proyectos" variant="solid">{t.portfolio.hero.ctaProjects}</CtaLink>
        <CtaLink href="#contacto">{t.portfolio.hero.ctaContact}</CtaLink>
      </div>
    </div>

    <footer class="meta" data-reveal style="--reveal-delay: 520ms">
      <span class="role">{t.portfolio.hero.role}</span>
      <ul class="stats" aria-label="Cifras clave">
        {stats.map((stat) => <li>{stat}</li>)}
      </ul>
    </footer>
  </div>
</section>

<style>
  .portfolio-hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: calc(var(--frame) + 6rem) 0 calc(var(--frame) + 2.5rem);
  }

  .inner {
    width: 100%;
    max-width: var(--container);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 1.4rem + 3vw, 3.5rem);
  }

  /* — cejilla: etiqueta · línea · ubicación — */
  .eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .rule {
    flex: 1;
    height: 1px;
    background: var(--color-line-soft);
  }

  .place {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.18em;
    color: var(--color-ink-faint);
    text-align: right;
  }

  /* — lockup del nombre: ADRIÁN 800 / D. BONILLA 300 — */
  .name {
    display: flex;
    align-items: baseline;
    gap: 0.75ch;
    text-transform: uppercase;
    line-height: 1;
  }

  .first {
    font-size: clamp(1.35rem, 1rem + 1.6vw, 2.1rem);
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .last {
    font-size: clamp(1rem, 0.75rem + 1.15vw, 1.55rem);
    font-weight: 300;
    letter-spacing: 0.06em;
  }

  /* — headline dominante — */
  .headline {
    font-size: clamp(2.5rem, 1.4rem + 5.6vw, 6.1rem);
    font-weight: 800;
    line-height: 1.03;
    letter-spacing: -0.03em;
    max-width: 16ch;
    text-wrap: balance;
  }

  /* — propuesta de valor + CTAs — */
  .row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .value {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    line-height: 1.55;
    max-width: 46ch;
    text-wrap: pretty;
  }

  .actions {
    display: flex;
    flex-shrink: 0;
    gap: var(--space-sm);
  }

  /* — barra de meta al pie — */
  .meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-lg);
    border-top: 1px solid var(--color-line-soft);
    padding-top: var(--space-sm);
  }

  .role {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.22em;
    color: var(--color-ink-muted);
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem var(--space-md);
  }

  .stats li {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
    color: var(--color-ink-faint);
  }

  @media (max-width: 820px) {
    .portfolio-hero {
      padding-top: calc(var(--frame) + 9rem);
    }

    .inner {
      gap: var(--space-md);
    }

    .row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
    }

    .actions {
      width: 100%;
      flex-direction: column;
    }

    .actions :global(.cta-link) {
      width: 100%;
    }

    .eyebrow .place {
      display: none;
    }

    .meta {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
