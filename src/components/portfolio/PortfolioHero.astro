---
/**
 * Hero del portafolio profesional: lockup del nombre (eco de la
 * portada artística), cargo, headline en Montserrat — tipografía
 * principal de la marca — propuesta de valor y CTAs.
 */
import { useTranslations } from '../../i18n';
import CtaLink from './CtaLink.astro';

const t = useTranslations('es');
---

<section class="portfolio-hero">
  <span class="label" data-reveal>{t.portfolio.hero.label}</span>

  <h1 class="name" data-reveal style="--reveal-delay: 100ms">
    <span class="first">{t.hero.firstName}</span>
    <span class="last">{t.hero.lastName}</span>
  </h1>

  <p class="role" data-reveal style="--reveal-delay: 200ms">{t.portfolio.hero.role}</p>

  <p class="headline" data-reveal style="--reveal-delay: 320ms">
    {t.portfolio.hero.headline}
  </p>

  <p class="value" data-reveal style="--reveal-delay: 440ms">
    {t.portfolio.hero.value}
  </p>

  <div class="actions" data-reveal style="--reveal-delay: 560ms">
    <CtaLink href="#proyectos" variant="solid">{t.portfolio.hero.ctaProjects}</CtaLink>
    <CtaLink href="#contacto">{t.portfolio.hero.ctaContact}</CtaLink>
  </div>

  <p class="location" data-reveal style="--reveal-delay: 680ms">
    {t.portfolio.hero.location}
  </p>
</section>

<style>
  .portfolio-hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-md);
    padding: calc(var(--frame) + 6.5rem) var(--gutter) calc(var(--frame) + 4rem);
  }

  /* lockup del nombre: ADRIÁN 800 / D. BONILLA 300, como en la marca */
  .name {
    display: flex;
    align-items: baseline;
    gap: 0.75ch;
    text-transform: uppercase;
    line-height: 1;
  }

  .first {
    font-size: clamp(1.6rem, 1.2rem + 2vw, 2.6rem);
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .last {
    font-size: clamp(1.15rem, 0.85rem + 1.4vw, 1.85rem);
    font-weight: 300;
    letter-spacing: 0.06em;
  }

  .role {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.3em;
    text-transform: lowercase;
    color: var(--color-ink-muted);
  }

  .headline {
    font-size: var(--text-hero);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.02em;
    max-width: 18ch;
    text-wrap: balance;
    margin-top: var(--space-sm);
  }

  .value {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    line-height: 1.55;
    max-width: 46ch;
    text-wrap: pretty;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .location {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.26em;
    color: var(--color-ink-faint);
    margin-top: var(--space-sm);
  }

  @media (max-width: 640px) {
    .name {
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
    }
  }
</style>
