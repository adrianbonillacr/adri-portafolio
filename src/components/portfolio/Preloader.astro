---
/**
 * Preloader de marca: velo a pantalla completa con el monograma AB
 * respirando. Se activa al hacer clic en cualquier enlace marcado con
 * `data-preloader` (selector de idioma, inicio) y navega al destino
 * tras la animación. Con `prefers-reduced-motion` navega de inmediato.
 */
import { getLangFromUrl, useTranslations } from '../../i18n';

const t = useTranslations(getLangFromUrl(Astro.url));
---

<div class="preloader" data-preloader-overlay aria-hidden="true">
  <img src="/assets/monogram.png" alt={t.a11y.monogramAlt} width="297" height="195" />
</div>

<script>
  const overlay = document.querySelector('[data-preloader-overlay]');
  const DURATION = 900;

  if (overlay) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll<HTMLAnchorElement>('a[data-preloader]').forEach((link) => {
      link.addEventListener('click', (event) => {
        const href = link.getAttribute('href');
        if (!href || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        event.preventDefault();
        if (reduced) {
          window.location.href = href;
          return;
        }
        overlay.classList.add('is-active');
        window.setTimeout(() => {
          window.location.href = href;
        }, DURATION);
      });
    });

    // al volver con el botón atrás (bfcache), ocultar el velo
    window.addEventListener('pageshow', (event) => {
      if (event.persisted) overlay.classList.remove('is-active');
    });
  }
</script>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 350ms var(--ease-out),
      visibility 0s linear 350ms;
  }

  .preloader.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 250ms var(--ease-out);
  }

  .preloader img {
    height: clamp(4.5rem, 10vw, 7rem);
    width: auto;
  }

  .preloader.is-active img {
    animation: preloader-breathe 1.1s var(--ease-out) infinite alternate;
  }

  @keyframes preloader-breathe {
    from {
      opacity: 0.45;
      transform: scale(0.97);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
