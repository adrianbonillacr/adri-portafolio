---
/**
 * Marca de «en preparación»: etiqueta mono con un punto que late.
 * Señala trabajo en curso de forma intencional —no como un hueco—
 * conservando el lenguaje del sitio: 1px, monocromo, sin color nuevo.
 */
interface Props {
  label: string;
  /** `overlay` se posiciona sobre un marco de media; `inline` fluye en línea. */
  variant?: 'overlay' | 'inline';
}

const { label, variant = 'inline' } = Astro.props;
---

<span class:list={['progress-tag', `is-${variant}`]}>
  <span class="pulse" aria-hidden="true"></span>
  {label}
</span>

<style>
  .progress-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.18em;
    color: var(--color-ink-muted);
    border: 1px solid var(--color-line-soft);
    padding: 0.35rem 0.8rem;
    background: var(--color-bg);
  }

  .is-overlay {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    pointer-events: none;
  }

  .pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-ink);
    animation: pulse 2s var(--ease-out) infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.25;
      transform: scale(0.75);
    }
    50% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse {
      animation: none;
      opacity: 0.7;
    }
  }
</style>
