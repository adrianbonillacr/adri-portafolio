---
/**
 * Galería del proyecto, totalmente funcional desde el día uno:
 * muestra lo que exista en `public/portfolio/<id>/gallery/`
 * (imágenes y videos, en orden alfabético) y, mientras no haya
 * archivos, marcos placeholder listos para recibirlos.
 *
 * Dos tratamientos:
 *  - Piezas sueltas en `gallery/` → retícula (½ o ⅓ de ancho).
 *  - Subcarpetas (`Fotos/`, `Historias/`…) → carrusel de una sola
 *    línea, con flechas y arrastre, para que una serie larga no
 *    alargue la página.
 *
 * Cada pieza abre el visor ampliado (Lightbox) al hacer clic.
 */
import { getLangFromUrl, useTranslations } from '../../i18n';
import type { GalleryCategory, GalleryItem } from '../../lib/media';
import MediaFrame from './MediaFrame.astro';
import SmartVideo from './SmartVideo.astro';
import Lightbox from './Lightbox.astro';
import ProgressTag from './ProgressTag.astro';

interface Props {
  items: GalleryItem[];
  categories?: GalleryCategory[];
  /** Cantidad de marcos vacíos cuando la carpeta aún no tiene archivos. */
  placeholders?: number;
  /** Series de video anunciadas como «en producción». */
  pendingSeries?: { name: string; count: number }[];
  /** Series ya publicadas que siguen ampliándose. */
  progressSeries?: string[];
  projectTitle: string;
}

const {
  items,
  categories = [],
  placeholders = 6,
  pendingSeries = [],
  progressSeries = [],
  projectTitle,
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const lb = t.portfolio.project.lightbox;
const isEmpty = items.length === 0 && categories.length === 0 && pendingSeries.length === 0;

/**
 * El sufijo del archivo controla el ANCHO que ocupa la pieza:
 *  - `-wide` → ancho completo
 *  - `-tall` → un tercio (historias, piezas verticales)
 *  - sin sufijo → media retícula
 *
 * La PROPORCIÓN es la real de la imagen (leída de su cabecera), de modo
 * que una pieza cuadrada o 4:5 se ve completa y sin recortes. Solo cuando
 * no se puede leer —los videos— se cae al valor derivado del sufijo.
 */
const isWide = (name: string) => name.endsWith('-wide');
const isTall = (name: string) => name.endsWith('-tall');
const ratioFor = (item: GalleryItem) =>
  item.ratio ??
  (isWide(item.name) ? '16 / 9' : isTall(item.name) ? '9 / 16' : item.type === 'video' ? '16 / 9' : '4 / 3');

/**
 * Cada serie se parte en filas por proporción: las 9:16 en una línea,
 * las cuadradas en otra, las 16:9 en otra. Así una carpeta con formatos
 * mezclados no deja el borde inferior irregular, porque dentro de cada
 * línea todas las piezas tienen la misma altura.
 *
 * Agrupa con una tolerancia relativa del 4%: junta lo que es el mismo
 * formato aunque venga con medidas ligeramente distintas (0.5625 y
 * 0.5628, o dos banners de 2.63 y 2.67) y separa formatos de verdad
 * distintos (1:1 de 4:5). El orden respeta la primera aparición.
 */
const RATIO_TOLERANCE = 0.04;

function ratioValue(item: GalleryItem): number {
  const [w = 1, h = 1] = ratioFor(item).split('/').map((n) => parseFloat(n.trim()));
  return w / h;
}

function splitByRatio(list: GalleryItem[]) {
  const rows: { value: number; items: GalleryItem[] }[] = [];
  for (const item of list) {
    const value = ratioValue(item);
    const row = rows.find((r) => Math.abs(r.value - value) / r.value < RATIO_TOLERANCE);
    if (row) row.items.push(item);
    else rows.push({ value, items: [item] });
  }
  return rows;
}
---

{
  isEmpty ? (
    <section class="gallery container">
      <span class="label" data-reveal>
        {t.portfolio.project.gallery}
      </span>
      <div class="grid">
        {Array.from({ length: placeholders }, (_, index) => (
          <div data-reveal style={`--reveal-delay: ${(index % 2) * 120}ms`}>
            <MediaFrame
              src={null}
              alt={`${projectTitle} — ${t.portfolio.project.imagePlaceholder} ${index + 1}`}
              ratio="4 / 3"
              label={`${t.portfolio.project.imagePlaceholder} — ${String(index + 1).padStart(2, '0')}`}
            />
          </div>
        ))}
      </div>
    </section>
  ) : (
    <section class="gallery container">
      <span class="label" data-reveal>
        {t.portfolio.project.gallery}
      </span>

      {items.length > 0 && (
        <div class="grid">
          {items.map((item, index) => (
            <div
              class:list={[{ 'is-wide': isWide(item.name), 'is-tall': isTall(item.name) }]}
              data-reveal
              style={`--reveal-delay: ${(index % 3) * 100}ms`}
            >
              <button
                class="piece"
                type="button"
                data-lightbox
                data-src={item.src}
                data-type={item.type}
                data-caption={`${projectTitle} — ${item.name}`}
                aria-label={`${lb.open}: ${projectTitle} — ${item.name}`}
              >
                {item.type === 'image' ? (
                  <MediaFrame
                    src={item.src}
                    alt={`${projectTitle} — ${item.name}`}
                    ratio={ratioFor(item)}
                  />
                ) : (
                  <SmartVideo
                    src={item.src}
                    ratio={ratioFor(item)}
                    mode="autoplay"
                    title={`${projectTitle} — ${item.name}`}
                  />
                )}
                <span class="frame" aria-hidden="true" />
                <span class="plus" aria-hidden="true" />
              </button>
            </div>
          ))}
        </div>
      )}

      {categories.map((category) => (
        <div class="category" data-reveal>
          {splitByRatio(category.items).map((row, rowIndex) => (
            <div class="cat-row">
              <div class="cat-head">
                <span class="cat-title">
                  <span class="category-label">{rowIndex === 0 ? category.name : ''}</span>
                  {rowIndex === 0 && progressSeries.includes(category.name) && (
                    <ProgressTag label={t.portfolio.project.seriesInProgress} />
                  )}
                </span>
                <div class="cat-nav">
                  <button class="arrow-btn" type="button" data-car-prev aria-label={lb.prev}>
                    <span class="arrow" aria-hidden="true" />
                  </button>
                  <button class="arrow-btn" type="button" data-car-next aria-label={lb.next}>
                    <span class="arrow" aria-hidden="true" />
                  </button>
                </div>
              </div>

              <div class="carousel" data-carousel>
                <div class="track" data-track>
                  {row.items.map((item) => (
                    <button
                      class:list={[
                        'piece',
                        'slide',
                        { 'is-wide': isWide(item.name), 'is-tall': isTall(item.name) },
                      ]}
                      type="button"
                      style={`--slide-ratio: ${ratioFor(item)}`}
                      data-lightbox
                      data-src={item.src}
                      data-type={item.type}
                      data-caption={`${projectTitle} — ${category.name} — ${item.name}`}
                      aria-label={`${lb.open}: ${projectTitle} — ${category.name} — ${item.name}`}
                    >
                      {item.type === 'image' ? (
                        <MediaFrame
                          src={item.src}
                          alt={`${projectTitle} — ${category.name} — ${item.name}`}
                          ratio={ratioFor(item)}
                        />
                      ) : (
                        <SmartVideo
                          src={item.src}
                          ratio={ratioFor(item)}
                          mode="autoplay"
                          title={`${projectTitle} — ${category.name} — ${item.name}`}
                        />
                      )}
                      <span class="frame" aria-hidden="true" />
                      <span class="plus" aria-hidden="true" />
                    </button>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      ))}

      {pendingSeries.map((serie) => (
        <div class="category is-pending" data-reveal>
          <div class="cat-head">
            <span class="category-label">{serie.name}</span>
          </div>
          <div class="carousel">
            <div class="track">
              {Array.from({ length: serie.count }, (_, index) => (
                <div class="slide is-tall" style="--slide-ratio: 9 / 16">
                  <SmartVideo
                    src={null}
                    ratio="9 / 16"
                    label={t.portfolio.project.videoPending}
                    title={`${projectTitle} — ${serie.name} — ${index + 1}`}
                  />
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}

      <Lightbox />
    </section>
  )
}

<script>
  // — Carrusel: cada fila navega en ciclo (de la última vuelve a la primera) —
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('[data-track]');
    if (!track) return;

    const row = carousel.closest('.cat-row');
    const prev = row?.querySelector<HTMLButtonElement>('[data-car-prev]');
    const next = row?.querySelector<HTMLButtonElement>('[data-car-next]');

    const amount = () => Math.max(track.clientWidth * 0.8, 240);
    const maxScroll = () => track.scrollWidth - track.clientWidth;

    function syncEnds() {
      // sin desbordamiento no hace falta navegar
      row?.classList.toggle('no-overflow', track.scrollWidth <= track.clientWidth + 2);
    }

    prev?.addEventListener('click', () => {
      // en el inicio, saltar al final
      const left = track.scrollLeft <= 1 ? maxScroll() : Math.max(0, track.scrollLeft - amount());
      track.scrollTo({ left, behavior: 'smooth' });
    });

    next?.addEventListener('click', () => {
      // al llegar al final, volver al principio
      const left = track.scrollLeft >= maxScroll() - 1 ? 0 : Math.min(maxScroll(), track.scrollLeft + amount());
      track.scrollTo({ left, behavior: 'smooth' });
    });

    window.addEventListener('resize', syncEnds);
    syncEnds();

    // — Arrastre con el puntero (además del scroll nativo y táctil) —
    let dragging = false;
    let startX = 0;
    let startScroll = 0;
    let moved = 0;

    track.addEventListener('pointerdown', (event) => {
      if (event.pointerType === 'touch') return; // el táctil ya desplaza solo
      dragging = true;
      moved = 0;
      startX = event.clientX;
      startScroll = track.scrollLeft;
      track.classList.add('is-dragging');
    });

    track.addEventListener('pointermove', (event) => {
      if (!dragging) return;
      const delta = event.clientX - startX;
      moved = Math.abs(delta);
      track.scrollLeft = startScroll - delta;
    });

    const endDrag = () => {
      if (!dragging) return;
      dragging = false;
      track.classList.remove('is-dragging');
    };

    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointerleave', endDrag);
    track.addEventListener('pointercancel', endDrag);

    // si se arrastró, no abrir el visor al soltar
    track.addEventListener(
      'click',
      (event) => {
        if (moved > 6) {
          event.preventDefault();
          event.stopPropagation();
          moved = 0;
        }
      },
      true
    );
  });
</script>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
  }

  /* — Pieza clicable: zoom sutil, marco fino y signo de ampliar — */
  .piece {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    cursor: pointer;
  }

  .piece :global(img),
  .piece :global(video) {
    transition: transform 900ms var(--ease-out);
  }

  .piece:hover :global(img),
  .piece:hover :global(video),
  .piece:focus-visible :global(img),
  .piece:focus-visible :global(video) {
    transform: scale(1.045);
  }

  /* marco interior que se cierra al pasar el cursor */
  .frame {
    position: absolute;
    inset: 14px;
    border: 1px solid rgba(244, 243, 240, 0.32);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity var(--dur-fast) var(--ease-out),
      inset var(--dur) var(--ease-out);
  }

  .piece:hover .frame,
  .piece:focus-visible .frame {
    opacity: 1;
    inset: 10px;
  }

  /* signo "+" de dos trazos, esquina inferior derecha */
  .plus {
    position: absolute;
    right: 20px;
    bottom: 20px;
    width: 13px;
    height: 13px;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity var(--dur-fast) var(--ease-out),
      translate var(--dur) var(--ease-out);
    translate: 0 4px;
  }

  .plus::before,
  .plus::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-ink);
  }

  .plus::after {
    rotate: 90deg;
  }

  .piece:hover .plus,
  .piece:focus-visible .plus {
    opacity: 1;
    translate: 0 0;
  }

  /* — Retícula de piezas sueltas: 6 pistas (½ · ⅓ · completo) — */
  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-md);
  }

  .grid > div {
    grid-column: span 3;
  }

  .grid .is-wide {
    grid-column: 1 / -1;
  }

  .grid .is-tall {
    grid-column: span 2;
  }

  /* — Categorías en carrusel: una fila por orientación — */
  .category {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cat-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .cat-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-line-soft);
  }

  /* las filas siguientes de una misma serie no repiten el título:
     su barra queda solo con las flechas y sin línea superior */
  .cat-row + .cat-row .cat-head {
    padding-top: 0;
    border-top: 0;
  }

  .cat-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .category-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.2em;
    color: var(--color-ink-faint);
  }

  .cat-nav {
    display: flex;
    gap: var(--space-2xs);
  }

  .cat-row.no-overflow .cat-nav {
    display: none;
  }

  .arrow-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--color-line-soft);
    color: var(--color-ink-muted);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out);
  }

  .arrow-btn:hover {
    color: var(--color-ink);
    border-color: var(--color-line);
  }

  .arrow {
    width: 9px;
    height: 9px;
    border-left: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
  }

  [data-car-prev] .arrow {
    transform: rotate(45deg);
    margin-left: 3px;
  }

  [data-car-next] .arrow {
    transform: rotate(-135deg);
    margin-right: 3px;
  }

  .carousel {
    position: relative;
  }

  .track {
    display: flex;
    /* cada pieza conserva su propia altura: sin esto, flex las estira
       todas a la más alta y se pierde la proporción real */
    align-items: flex-start;
    gap: var(--space-sm);
    overflow-x: auto;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    /* deja aire para el marco y el "+" del hover */
    padding-block: 2px;
  }

  .track::-webkit-scrollbar {
    display: none;
  }

  .track.is-dragging {
    scroll-snap-type: none;
    cursor: grabbing;
    scroll-behavior: auto;
  }

  /* Una sola línea, conservando el tamaño que cada pieza tenía en la
     retícula: ⅓ del contenedor para las verticales, ½ para las normales
     y ancho completo para las panorámicas. La altura la da la proporción,
     puesta en el propio slide para que no dependa de la carga de la imagen. */
  .slide {
    flex: 0 0 auto;
    width: calc((100% - var(--space-md)) / 2);
    height: auto;
    aspect-ratio: var(--slide-ratio, 4 / 3);
    scroll-snap-align: start;
  }

  .slide.is-tall {
    width: calc((100% - 2 * var(--space-md)) / 3);
  }

  .slide.is-wide {
    width: 100%;
  }

  .slide :global(.media-frame),
  .slide :global(.smart-video) {
    height: 100%;
    width: 100%;
    aspect-ratio: auto;
  }

  @media (max-width: 700px) {
    .grid {
      gap: var(--space-sm);
    }

    /* móvil: piezas normales a lo ancho; verticales de a dos por fila */
    .grid > div {
      grid-column: 1 / -1;
    }

    .grid .is-tall {
      grid-column: span 3;
    }

    /* móvil: mismas fracciones que la retícula (½ para verticales) */
    .slide,
    .slide.is-tall {
      width: calc((100% - var(--space-sm)) / 2);
    }

    .slide.is-wide {
      width: 100%;
    }
  }
</style>
