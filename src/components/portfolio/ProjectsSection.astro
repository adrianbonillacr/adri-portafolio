---
/**
 * Grid de proyectos principales: lee la colección `projects`
 * y renderiza una tarjeta premium por caso de estudio.
 */
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n';
import { getProjectMedia } from '../../lib/media';
import SectionHeader from './SectionHeader.astro';
import ProjectCard from './ProjectCard.astro';

const t = useTranslations('es');
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<section id="proyectos" class="projects container">
  <SectionHeader
    label={t.portfolio.projects.label}
    title={t.portfolio.projects.title}
    intro={t.portfolio.projects.intro}
  />

  <div class="grid">
    {
      projects.map((project, index) => (
        <ProjectCard
          href={`/portafolio/${project.id}`}
          title={project.data.title}
          tagline={project.data.tagline}
          disciplines={project.data.disciplines}
          index={index}
          image={getProjectMedia(project.id).hero}
        />
      ))
    }
  </div>
</section>

<style>
  .projects {
    padding-block: var(--space-section) 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  /* con cantidad impar de espacios, el último ocupa el ancho completo */
  .grid > :global(.project-card:last-child:nth-child(odd)) {
    grid-column: 1 / -1;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
