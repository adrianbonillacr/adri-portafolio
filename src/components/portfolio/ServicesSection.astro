---
/**
 * Servicios profesionales: lista editorial numerada
 * leída desde `content/services.json`.
 */
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n';
import SectionHeader from './SectionHeader.astro';

const t = useTranslations('es');
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<section id="servicios" class="services container">
  <SectionHeader label={t.portfolio.services.label} title={t.portfolio.services.title} />

  <ol>
    {
      services.map((service, index) => (
        <li data-reveal style={`--reveal-delay: ${(index % 2) * 120}ms`}>
          <span class="index" aria-hidden="true">
            {String(index + 1).padStart(2, '0')}
          </span>
          <div class="body">
            <h3>{service.data.title}</h3>
            <p>{service.data.description}</p>
            <ul class="deliverables">
              {service.data.deliverables.map((deliverable) => (
                <li>{deliverable}</li>
              ))}
            </ul>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .services {
    padding-block: var(--space-section);
  }

  ol {
    display: flex;
    flex-direction: column;
  }

  ol > li {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-md);
    padding-block: var(--space-md);
    border-top: 1px solid var(--color-line-soft);
  }

  ol > li:last-child {
    border-bottom: 1px solid var(--color-line-soft);
  }

  .index {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.3em;
    color: var(--color-ink-faint);
    padding-top: 0.5rem;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  h3 {
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.015em;
  }

  p {
    color: var(--color-ink-muted);
    max-width: 52ch;
  }

  .deliverables {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-2xs);
  }

  .deliverables li {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.14em;
    text-transform: lowercase;
    color: var(--color-ink-faint);
    border: 1px solid var(--color-line-soft);
    padding: 0.3rem 0.7rem;
  }

  @media (max-width: 640px) {
    ol > li {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }

    .index {
      padding-top: 0;
    }
  }
</style>
