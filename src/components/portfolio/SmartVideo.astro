---
/**
 * Video consciente de placeholders, servido directo desde /public.
 * Modos:
 *  - autoplay : silencioso, en bucle constante. No descarga nada hasta
 *               acercarse a la pantalla (`preload="none"` + IntersectionObserver):
 *               ahí empieza a cargar y reproducir, y se pausa al salir.
 *               Sin esto, un reel con videos pesados descargaría decenas
 *               de MB al abrir la página.
 *  - hover    : se reproduce al pasar el cursor (heredado; ya no se usa)
 *  - controls : controles nativos (incluye fullscreen)
 * Con `prefers-reduced-motion` el autoplay se desactiva (queda el primer
 * cuadro). Si `src` es null se muestra un marco vacío listo para el archivo.
 */
import ProgressTag from './ProgressTag.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';

interface Props {
  src: string | null;
  ratio?: string;
  mode?: 'autoplay' | 'hover' | 'controls';
  poster?: string | null;
  /** Etiqueta del placeholder cuando no hay video. */
  label?: string;
  /** Descripción accesible del contenido del video. */
  title?: string;
}

const {
  src,
  ratio = '16 / 9',
  mode = 'autoplay',
  poster = null,
  label = 'video',
  title = label,
} = Astro.props;

/**
 * Tamaño de exportación recomendado según la proporción:
 * panorámicos (≥2:1) 2400px de ancho, horizontales 1920px (Full HD),
 * verticales 1080px; la altura se deriva del ratio.
 */
const showSpecs = import.meta.env.DEV;
const t = useTranslations(getLangFromUrl(Astro.url));

const [ratioW = 16, ratioH = 9] = ratio.split('/').map((part) => parseFloat(part.trim()));
const aspect = ratioW / ratioH;
const exportWidth = aspect >= 2 ? 2400 : aspect >= 1 ? 1920 : 1080;
const exportHeight = Math.round(exportWidth / aspect);
const ratioLabel = `${ratioW}:${ratioH}`;
const sizeLabel = `${exportWidth}px × ${exportHeight}px`;
---

<figure class="smart-video" style={`--ratio: ${ratio}`}>
  {
    src ? (
      <video
        src={src}
        poster={poster ?? undefined}
        preload={mode === 'autoplay' ? 'none' : 'metadata'}
        playsinline
        muted={mode !== 'controls'}
        loop={mode !== 'controls'}
        controls={mode === 'controls'}
        data-video-auto={mode === 'autoplay' ? '' : undefined}
        data-video-hover={mode === 'hover' ? '' : undefined}
        aria-label={title}
      />
    ) : (
      <span class="placeholder" role="img" aria-label={title}>
        <span class="play" aria-hidden="true" />
        {
          showSpecs ? (
            <>
              <span class="tag">{label}</span>
              <span class="spec">{ratioLabel}</span>
              <span class="spec">{sizeLabel}</span>
            </>
          ) : (
            <ProgressTag label={t.portfolio.project.mediaPending} />
          )
        }
      </span>
    )
  }
</figure>

<script>
  // — Autoplay en loop constante, gobernado por visibilidad —
  // Astro deduplica este script aunque haya varios SmartVideo en la página.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const autoVideos = document.querySelectorAll<HTMLVideoElement>('video[data-video-auto]');

  if (autoVideos.length > 0) {
    if (reduceMotion) {
      // sin animación: cargar solo el primer cuadro, sin reproducir
      autoVideos.forEach((v) => {
        v.preload = 'metadata';
      });
    } else if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const video = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) {
              // la descarga empieza aquí, no al abrir la página
              if (video.preload !== 'auto') video.preload = 'auto';
              const p = video.play();
              if (p) p.catch(() => {});
            } else {
              video.pause();
            }
          }
        },
        // margen para que empiece a cargar justo antes de entrar en pantalla
        { threshold: 0.2, rootMargin: '300px 0px' }
      );
      autoVideos.forEach((v) => io.observe(v));
    }
  }

  // — Modo hover heredado (ya no se usa en galerías, se conserva por compatibilidad) —
  document.querySelectorAll<HTMLVideoElement>('video[data-video-hover]').forEach((video) => {
    video.addEventListener('mouseenter', () => video.play());
    video.addEventListener('mouseleave', () => video.pause());
  });
</script>

<style>
  .smart-video {
    position: relative;
    aspect-ratio: var(--ratio);
    overflow: hidden;
    background: var(--color-bg-raised);
    border: 1px solid var(--color-line-soft);
  }

  video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .placeholder .play {
    margin-bottom: 0.5rem;
  }

  .spec {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }

  /* triángulo de reproducción trazado, en espera del archivo */
  .play {
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-line);
    border-radius: 50%;
    position: relative;
  }

  .play::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 53%;
    translate: -50% -50%;
    border-style: solid;
    border-width: 6px 0 6px 10px;
    border-color: transparent transparent transparent var(--color-ink-faint);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.3em;
    color: var(--color-ink-faint);
  }
</style>
