---
/**
 * Video consciente de placeholders, servido directo desde /public.
 * Modos:
 *  - autoplay : silencioso, en bucle (heros, ambiente)
 *  - hover    : se reproduce al pasar el cursor
 *  - controls : controles nativos (incluye fullscreen)
 * Si `src` es null se muestra un marco vacío listo para recibir el archivo.
 */
interface Props {
  src: string | null;
  ratio?: string;
  mode?: 'autoplay' | 'hover' | 'controls';
  poster?: string | null;
  /** Etiqueta del placeholder cuando no hay video. */
  label?: string;
  /** Descripción accesible del contenido del video. */
  title?: string;
}

const {
  src,
  ratio = '16 / 9',
  mode = 'autoplay',
  poster = null,
  label = 'video',
  title = label,
} = Astro.props;
---

<figure class="smart-video" style={`--ratio: ${ratio}`}>
  {
    src ? (
      <video
        src={src}
        poster={poster ?? undefined}
        preload="metadata"
        playsinline
        muted={mode !== 'controls'}
        loop={mode !== 'controls'}
        autoplay={mode === 'autoplay'}
        controls={mode === 'controls'}
        data-video-hover={mode === 'hover' ? '' : undefined}
        aria-label={title}
      />
    ) : (
      <span class="placeholder" role="img" aria-label={title}>
        <span class="play" aria-hidden="true" />
        <span class="tag">{label}</span>
      </span>
    )
  }
</figure>

<script>
  // reproduce/pausa los videos en modo hover; Astro deduplica este script
  document.querySelectorAll<HTMLVideoElement>('video[data-video-hover]').forEach((video) => {
    video.addEventListener('mouseenter', () => video.play());
    video.addEventListener('mouseleave', () => video.pause());
  });
</script>

<style>
  .smart-video {
    position: relative;
    aspect-ratio: var(--ratio);
    overflow: hidden;
    background: var(--color-bg-raised);
    border: 1px solid var(--color-line-soft);
  }

  video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
  }

  /* triángulo de reproducción trazado, en espera del archivo */
  .play {
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-line);
    border-radius: 50%;
    position: relative;
  }

  .play::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 53%;
    translate: -50% -50%;
    border-style: solid;
    border-width: 6px 0 6px 10px;
    border-color: transparent transparent transparent var(--color-ink-faint);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.3em;
    color: var(--color-ink-faint);
  }
</style>
