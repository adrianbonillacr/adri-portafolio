---
/**
 * English nested case study (Advance, Lagé, Freelance) — same exact
 * architecture as a workspace page, with placeholder content until
 * phase 2. Media lives in public/portfolio/<project>/<caso>/.
 */
import { getCollection } from 'astro:content';
import Base from '../../../../layouts/Base.astro';
import { useTranslations } from '../../../../i18n';
import '../../../../styles/portfolio.css';
import PortfolioNav from '../../../../components/portfolio/PortfolioNav.astro';
import CaseStudyArticle from '../../../../components/portfolio/CaseStudyArticle.astro';
import Preloader from '../../../../components/portfolio/Preloader.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projectsEn');

  return projects
    .filter((project) => project.data.caseStudies.length > 0)
    .flatMap((project) =>
      project.data.caseStudies.map((caseStudy, index) => {
        const siblings = project.data.caseStudies;
        const next = siblings[(index + 1) % siblings.length];
        return {
          params: { project: project.id, caso: caseStudy.id },
          props: {
            parentId: project.id,
            parentTitle: project.data.title,
            caseStudy,
            next: {
              title: `${next.title} — ${project.data.title}`,
              href: `/en/portfolio/${project.id}/${next.id}`,
            },
          },
        };
      })
    );
}

const { parentId, parentTitle, caseStudy, next } = Astro.props;
const t = useTranslations('en');
const path = `/en/portfolio/${parentId}/${caseStudy.id}`;

/** Real case content when defined in the workspace JSON; placeholders otherwise. */
const content = {
  challenge:
    caseStudy.challenge ??
    '[Placeholder] The business or brand problem that existed before this case began.',
  objective:
    caseStudy.objective ?? '[Placeholder] What this case aimed to achieve: concrete, measurable goals.',
  role: caseStudy.role ?? '[Placeholder] My role within this case: responsibilities and scope.',
  strategy: caseStudy.strategy ?? '[Placeholder] The strategy behind the decisions of this case.',
  process: caseStudy.process ?? [
    { title: '[Stage 01]', description: '[Placeholder] Brief description of this stage.' },
    { title: '[Stage 02]', description: '[Placeholder] Brief description of this stage.' },
    { title: '[Stage 03]', description: '[Placeholder] Brief description of this stage.' },
  ],
  results: caseStudy.results ?? {
    summary: '[Placeholder] Summary of this case’s results.',
    metrics: [
      { value: '00%', label: '[Placeholder] metric' },
      { value: '00%', label: '[Placeholder] metric' },
      { value: '00', label: '[Placeholder] metric' },
    ],
  },
};

const title = `${caseStudy.title} — ${parentTitle} · ${t.hero.firstName} ${t.hero.lastName}`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: `${caseStudy.title} — ${parentTitle}`,
    description: caseStudy.description,
    url: new URL(path, Astro.site).href,
    inLanguage: 'en',
    isPartOf: {
      '@type': 'CreativeWork',
      name: parentTitle,
      url: new URL(`/en/portfolio/${parentId}`, Astro.site).href,
    },
    author: {
      '@type': 'Person',
      name: `${t.hero.firstName} ${t.hero.lastName}`,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: t.portfolio.meta.title,
        item: new URL('/en/portfolio', Astro.site).href,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: parentTitle,
        item: new URL(`/en/portfolio/${parentId}`, Astro.site).href,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: caseStudy.title,
        item: new URL(path, Astro.site).href,
      },
    ],
  },
];
---

<Base title={title} description={caseStudy.description} path={path} schema={schema} lang="en">
  <PortfolioNav />
  <main id="contenido">
    <CaseStudyArticle
      mediaId={`${parentId}/${caseStudy.id}`}
      title={caseStudy.title}
      tagline={caseStudy.tagline}
      description={caseStudy.description}
      disciplines={[]}
      challenge={content.challenge}
      objective={content.objective}
      role={content.role}
      strategy={content.strategy}
      process={content.process}
      results={content.results}
      next={next}
      backHref={`/en/portfolio/${parentId}`}
      backLabel={parentTitle}
    />
  </main>
  <Preloader />
</Base>
